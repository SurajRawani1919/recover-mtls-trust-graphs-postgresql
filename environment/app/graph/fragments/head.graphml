<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns
         http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <graph id="mtls-trust" edgedefault="directed">
    <node id="n_auth_v1">
      <data key="d_svc">svc-auth-01</data>
      <data key="d_label">Auth Service</data>
      <data key="d_serial">AUTH-0001</data>
      <data key="d_version">1</data>
    </node>
    <node id="n_pay">
      <data key="d_svc">svc-pay-02</data>
      <data key="d_label">Payment Service</data>
      <data key="d_serial">PAY-0002</data>
      <data key="d_version">1</data>
    </node>
    <node id="n_auth_dup">
      <data key="d_svc">svc-auth-01</data>
      <data key="d_label">Auth Service Canonical</data>
      <data key="d_serial">AUTH-0001</data>
      <data key="d_version">2</data>
    </node>
    <node id="n_legacy">
      <data key="d_svc">svc-legacy-99</data>
      <data key="d_label">Legacy Gateway</data>
      <data key="d_serial">LEGACY-0099</data>
      <data key="d_version">1</data>
    </node>
