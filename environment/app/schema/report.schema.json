{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mTLS Graph Recovery Report",
  "type": "object",
  "required": [
    "task",
    "timestamp",
    "input_file",
    "repairs",
    "xsd_validation",
    "verification",
    "database",
    "status"
  ],
  "properties": {
    "task": { "type": "string" },
    "timestamp": { "type": "string" },
    "input_file": { "type": "string" },
    "repairs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "detail"],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "merge_fragments",
              "inject_keys",
              "deduplicate_nodes",
              "reattach_signatures"
            ]
          },
          "detail": { "type": "string" }
        }
      }
    },
    "xsd_validation": {
      "type": "object",
      "required": ["passed", "schema_url"],
      "properties": {
        "passed": { "type": "boolean" },
        "schema_url": { "type": "string" },
        "errors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "verification": {
      "type": "object",
      "required": [
        "nodes_checked",
        "nodes_verified",
        "edges_checked",
        "edges_verified"
      ],
      "properties": {
        "nodes_checked": { "type": "integer", "minimum": 0 },
        "nodes_verified": { "type": "integer", "minimum": 0 },
        "edges_checked": { "type": "integer", "minimum": 0 },
        "edges_verified": { "type": "integer", "minimum": 0 },
        "rejected_nodes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rejected_edges": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "database": {
      "type": "object",
      "required": ["nodes_loaded", "edges_loaded", "copy_duration_ms"],
      "properties": {
        "nodes_loaded": { "type": "integer", "minimum": 0 },
        "edges_loaded": { "type": "integer", "minimum": 0 },
        "copy_duration_ms": { "type": "number", "minimum": 0 }
      }
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed"]
    }
  },
  "additionalProperties": false
}
